union : Eq a => {xs : List a, ys : List a} -> List a
union [] [] = []
union [] [1] = [1]
union [1] [] = [1]
union [1] [1] = [1]
union [2] [1] = [2, 1]
union [] [2, 1] = [2, 1]
union [1, 2] [] = [1, 2]
union [1, 1] [] = [1, 1]
union [1, 1] [1] = [1, 1]
union [1] [2, 1] = [1, 2]
union [1, 1] [2, 1] = [1, 1, 2]
union [1, 2] [3] = [1, 2, 3]
union [1, 2] [2] = [1, 2]
