elemIndex : Eq a => {x : a, xs : List a} -> Maybe Nat
elemIndex 1 [] = Nothing
elemIndex 1 [2] = Nothing
elemIndex 1 [2,3] = Nothing
elemIndex 1 [2,3,4] = Nothing
elemIndex 1 [1] = Just 0
elemIndex 1 [2,1] = Just 1
elemIndex 1 [1,2] = Just 0
