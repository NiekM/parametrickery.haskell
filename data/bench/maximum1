maximum1 : Ord a => {xs : Some a} -> a
maximum1 (Cons (1, Nothing)) = 1
maximum1 (Cons (1, Just (Cons (1, Nothing)))) = 1
maximum1 (Cons (2, Just (Cons (1, Nothing)))) = 2
maximum1 (Cons (1, Just (Cons (2, Nothing)))) = 2
maximum1 (Cons (1, Just (Cons (1, Just (Cons (1, Nothing)))))) = 1
maximum1 (Cons (1, Just (Cons (2, Just (Cons (1, Nothing)))))) = 2
maximum1 (Cons (2, Just (Cons (1, Just (Cons (1, Nothing)))))) = 2
maximum1 (Cons (2, Just (Cons (2, Just (Cons (1, Nothing)))))) = 2
maximum1 (Cons (3, Just (Cons (2, Just (Cons (1, Nothing)))))) = 3