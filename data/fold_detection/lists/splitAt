splitAt : {n : Nat, xs : List a} -> (List a, List a)
splitAt 1 [1, 2, 3] = ([1], [2, 3])
splitAt 1 [True, False] = ([True], [False])
splitAt 1 [()] = ([()],[])
splitAt 1 [] = ([],[])
splitAt 2 [1, 2, 3] = ([1, 2], [3])
splitAt 2 [True, False] = ([True, False], [])
splitAt 2 [()] = ([()],[])
splitAt 2 [] = ([],[])
